aws_region   = "us-east-1"
project_name = "starttech"
environment  = "dev"

availability_zones = ["us-east-1a", "us-east-1b"]

backend_instance_type    = "t3.micro"
backend_min_size         = 1
backend_max_size         = 3
backend_desired_capacity = 2

redis_node_type = "cache.t3.micro"

backend_image = "docker.io/YOUR_DOCKERHUB_USER/much-to-do:latest"

mongo_uri = "mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/much_todo_db"

tags = {
  Project   = "starttech"
  ManagedBy = "terraform"
}
